generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id         Int       @id @default(autoincrement())
  email      String    @unique
  password   String    @db.Text
  role       String?   @default("user") @db.VarChar(20)
  balance    Float     @default(0)
  createdAt  DateTime  @default(now()) @map("created_at")

  profile    Profile?
  products   Product[]
  likes      ProductLike[]
  boosts     ProductBoost[]
  withdrawals Withdrawal[]
  notifications Notification[]
  reports    Report[]
  followers  Follow[] @relation("UserFollowers")
  following  Follow[] @relation("UserFollowing")

  @@map("users")
}

model Profile {
  id         Int       @id @default(autoincrement())
  userId     Int       @unique @map("user_id")
  name       String?   @db.VarChar(100)
  phone      String?   @db.VarChar(20)
  address    String?   @db.Text
  avatar     String?   @db.Text
  notificationsEnabled Boolean? @default(true)
  privacyProfilePublic Boolean? @default(true)
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model Category {
  id         Int       @id @default(autoincrement())
  name       String?   @db.VarChar(100)
  parentId   Int?      @map("parent_id")
  
  parent     Category?  @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: SetNull)
  children   Category[] @relation("CategoryToCategory")
  products   Product[]

  @@map("categories")
}

model Product {
  id          Int        @id @default(autoincrement())
  userId      Int?       @map("user_id")
  categoryId  Int?       @map("category_id")
  title       String?    @db.VarChar(255)
  description String?    @db.Text
  price       BigInt?
  type        ProductType?
  condition   String?    @db.VarChar(100)
  size        String?    @db.VarChar(100)
  brand       String?    @db.VarChar(100)
  dealMethod  DealMethod? @map("deal_method")
  location    String?    @db.VarChar(255)
  status      String?    @default("available") @db.VarChar(20)
  deletedAt   DateTime?  @map("deleted_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  user        User?      @relation(fields: [userId], references: [id])
  category    Category?  @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  likes       ProductLike[]
  boosts      ProductBoost[]
  reports     Report[]

  @@index([type], name: "idx_product_type")
  @@index([status, deletedAt], name: "idx_product_status_deleted")
  @@map("products")
}

enum ProductType {
  jual
  hibah
}

enum DealMethod {
  pickup
  delivery
  both
}

model ProductImage {
  id         Int       @id @default(autoincrement())
  productId  Int?      @map("product_id")
  imageUrl   String?   @db.Text

  product    Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductLike {
  id         Int       @id @default(autoincrement())
  userId     Int?      @map("user_id")
  productId  Int?      @map("product_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User?     @relation(fields: [userId], references: [id])
  product    Product?  @relation(fields: [productId], references: [id])

  @@unique([userId, productId], name: "unique_like")
  @@map("product_likes")
}

model ChatRoom {
  id         Int       @id @default(autoincrement())
  productId  Int?      @map("product_id")
  buyerId    Int?      @map("buyer_id")
  sellerId   Int?      @map("seller_id")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([buyerId], name: "idx_chatroom_buyer")
  @@index([sellerId], name: "idx_chatroom_seller")
  @@map("chat_rooms")
}

model PriceOffer {
  id          Int       @id @default(autoincrement())
  productId   Int?      @map("product_id")
  buyerId     Int?      @map("buyer_id")
  offerPrice  BigInt?   @map("offer_price")
  status      String?   @default("pending") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([productId], name: "idx_offer_product")
  @@index([buyerId], name: "idx_offer_buyer")
  @@map("price_offers")
}

model Transaction {
  id          Int       @id @default(autoincrement())
  productId   Int?      @map("product_id")
  buyerId     Int?      @map("buyer_id")
  sellerId    Int?      @map("seller_id")
  totalPrice  BigInt?   @map("total_price")
  status      String?   @default("pending") @db.VarChar(20)
  createdAt   DateTime  @default(now()) @map("created_at")

  payments    Payment[]
  history     OrderStatusHistory[]
  reviews     Review[]

  @@index([buyerId], name: "idx_trx_buyer")
  @@index([sellerId], name: "idx_trx_seller")
  @@index([productId], name: "idx_trx_product")
  @@map("transactions")
}

model Payment {
  id               Int       @id @default(autoincrement())
  transactionId    Int?      @map("transaction_id")
  paymentMethod    String?   @db.VarChar(50)
  paymentStatus    String?   @db.VarChar(50)
  midtransOrderId  String?   @db.VarChar(255) @map("midtrans_order_id")
  amount           BigInt?
  createdAt        DateTime  @default(now()) @map("created_at")

  transaction      Transaction? @relation(fields: [transactionId], references: [id])

  @@index([transactionId], name: "idx_payment_trx")
  @@map("payments")
}

model OrderStatusHistory {
  id            Int       @id @default(autoincrement())
  transactionId Int?      @map("transaction_id")
  status        String?   @db.VarChar(50)
  note          String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  @@index([transactionId], name: "idx_history_trx")
  @@map("order_status_history")
}

model ShippingOption {
  id        Int      @id @default(autoincrement())
  label     String   @db.VarChar(100)
  price     Int      @default(0)
  eta       String   @db.VarChar(50)
  icon      String?  @db.VarChar(10)
  isActive  Boolean  @default(true) @map("is_active")

  @@map("shipping_options")
}

model HibahRequest {
  id           Int       @id @default(autoincrement())
  productId    Int?      @map("product_id")
  requesterId  Int?      @map("requester_id")
  message      String?   @db.Text
  status       String?   @default("pending") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([productId], name: "idx_hibah_product")
  @@index([requesterId], name: "idx_hibah_requester")
  @@map("hibah_requests")
}

model Review {
  id             Int       @id @default(autoincrement())
  transactionId  Int?      @map("transaction_id")
  reviewerId     Int?      @map("reviewer_id")
  rating         Int?
  comment        String?   @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")

  transaction    Transaction? @relation(fields: [transactionId], references: [id])

  @@index([transactionId], name: "idx_review_trx")
  @@map("reviews")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(255)
  token     String   @unique @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email], name: "idx_pwd_reset_email")
  @@map("password_reset_tokens")
}

model ProductBoost {
  id              Int       @id @default(autoincrement())
  productId       Int       @map("product_id")
  userId          Int       @map("user_id")
  durationDays    Int       @map("duration_days")
  price           Int
  status          String    @default("pending") @db.VarChar(20) // pending_payment, pending_approval, active, expired, rejected
  paymentMethod   String?   @db.VarChar(50)
  midtransOrderId String?   @map("midtrans_order_id") @db.VarChar(255)
  activeUntil     DateTime? @map("active_until")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId], name: "idx_boost_product")
  @@index([status, activeUntil], name: "idx_boost_status_date")
  @@map("product_boosts")
}

model Withdrawal {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  amount        Float
  bankName      String   @db.VarChar(100)
  accountNumber String   @db.VarChar(100)
  accountName   String   @db.VarChar(100)
  status        String   @default("pending") @db.VarChar(50) // pending, approved, rejected
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_withdrawal_user")
  @@index([status], name: "idx_withdrawal_status")
  @@map("withdrawals")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String   @db.VarChar(255)
  message   String   @db.Text
  link      String?  @db.VarChar(255)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_notification_user")
  @@map("notifications")
}

model Report {
  id          Int      @id @default(autoincrement())
  productId   Int      @map("product_id")
  reporterId  Int      @map("reporter_id")
  reason      String   @db.VarChar(255)
  details     String?  @db.Text
  status      String   @default("pending") @db.VarChar(50) // pending, reviewed, resolved, rejected
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  reporter    User     @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([productId], name: "idx_report_product")
  @@index([reporterId], name: "idx_report_reporter")
  @@index([status], name: "idx_report_status")
  @@map("reports")
}

model Follow {
  id          Int      @id @default(autoincrement())
  followerId  Int      @map("follower_id")
  followingId Int      @map("following_id")
  createdAt   DateTime @default(now()) @map("created_at")

  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId], name: "idx_follow_follower")
  @@index([followingId], name: "idx_follow_following")
  @@map("follows")
}
